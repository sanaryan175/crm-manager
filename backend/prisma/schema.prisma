generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum ContactStatus {
  active
  inactive
  blocked
}

enum ContactSource {
  website
  referral
  cold_outreach
  event
  partner
  other
}

enum DealStage {
  new
  contacted
  demo_scheduled
  proposal_sent
  negotiation
  closed_won
  closed_lost
}

enum DealPriority {
  low
  medium
  high
}

enum DealCloseReason {
  won
  lost
  no_decision
  cancelled
}

enum ActivityType {
  call
  email
  meeting
  note
  task
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  invite_sent
  invite_accepted
  invite_revoked
  permission_changed
  role_changed
}

// ─── Multi-Tenant Core ────────────────────────────────────────────────────────

model Organization {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  logo         String?
  industry     String?
  website      String?
  country      String   @default("US")
  currency     String   @default("USD")
  timezone     String   @default("UTC")
  fiscalYear   Int      @default(1) @map("fiscal_year")   // month number 1-12
  companySize  String?  @map("company_size")
  businessHours String? @map("business_hours")
  isActive     Boolean  @default(true) @map("is_active")
  setupComplete Boolean @default(false) @map("setup_complete")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  users        User[]
  roles        Role[]
  permissions  Permission[]
  invitations  Invitation[]
  contacts     Contact[]
  deals        Deal[]
  activities   Activity[]
  auditLogs    AuditLog[]

  @@map("organizations")
}

// ─── RBAC Core ────────────────────────────────────────────────────────────────

model Role {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String                           // e.g. "owner", "admin", "sales_manager"
  displayName    String   @map("display_name")   // e.g. "Sales Manager"
  description    String?
  isSystem       Boolean  @default(false) @map("is_system") // built-in, not deletable
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  rolePermissions RolePermission[]
  invitations    Invitation[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  resource       String                          // e.g. "deal", "contact", "user"
  action         String                          // e.g. "create", "read", "update", "delete"
  name           String                          // e.g. "deal.create" (computed: resource.action)
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([organizationId, name])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(uuid())
  organizationId     String   @map("organization_id")
  roleId             String   @map("role_id")
  name               String
  email              String
  password           String
  isActive           Boolean  @default(true) @map("is_active")
  avatar             String?
  isOwner            Boolean  @default(false) @map("is_owner")
  onboardingComplete Boolean  @default(true) @map("onboarding_complete")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role               Role         @relation(fields: [roleId], references: [id])
  sentInvitations    Invitation[] @relation("InvitationSender")
  assignedContacts   Contact[]    @relation("ContactAssignee")
  createdContacts    Contact[]    @relation("ContactCreator")
  assignedDeals      Deal[]       @relation("DealAssignee")
  createdDeals       Deal[]       @relation("DealCreator")
  assignedActivities Activity[]   @relation("ActivityAssignee")
  createdActivities  Activity[]   @relation("ActivityCreator")
  auditLogs          AuditLog[]

  @@unique([organizationId, email])
  @@map("users")
}

// ─── Invitations ──────────────────────────────────────────────────────────────

model Invitation {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  email          String
  roleId         String           @map("role_id")
  invitedById    String           @map("invited_by_id")
  token          String           @unique   // secure random token (hashed in DB)
  tokenPrefix    String?          @map("token_prefix")
  status         InvitationStatus @default(pending)
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  invitedBy    User         @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([tokenPrefix, status])
  @@map("invitations")
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  userId         String?     @map("user_id")
  action         AuditAction
  resource       String      // e.g. "deal", "user", "contact"
  resourceId     String?     @map("resource_id")
  metadata       Json?       // before/after state, IP, etc.
  ipAddress      String?     @map("ip_address")
  userAgent      String?     @map("user_agent")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ─── CRM Models (all tenant-scoped) ──────────────────────────────────────────

model Contact {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  email          String
  phone          String?
  company        String?
  jobTitle       String?       @map("job_title")
  status         ContactStatus @default(active)
  source         ContactSource @default(other)
  tags           String[]
  notes          String?
  assignedToId   String?       @map("assigned_to_id")
  createdById    String        @map("created_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("ContactAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("ContactCreator", fields: [createdById], references: [id])
  deals        Deal[]
  activities   Activity[]

  @@map("contacts")
}

model Deal {
  id                String           @id @default(uuid())
  organizationId    String           @map("organization_id")
  title             String
  contactId         String?          @map("contact_id")
  company           String?
  value             Float
  currency          String           @default("USD")
  stage             DealStage        @default(new)
  priority          DealPriority     @default(medium)
  expectedCloseDate DateTime?        @map("expected_close_date")
  closeReason       DealCloseReason? @map("close_reason")
  closedAt          DateTime?        @map("closed_at")
  assignedToId      String?          @map("assigned_to_id")
  createdById       String           @map("created_by_id")
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("DealAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("DealCreator", fields: [createdById], references: [id])
  activities   Activity[]

  @@map("deals")
}

model Activity {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  type           ActivityType
  subject        String
  description    String?
  contactId      String?      @map("contact_id")
  dealId         String?      @map("deal_id")
  assignedToId   String?      @map("assigned_to_id")
  dueDate        DateTime?    @map("due_date")
  completed      Boolean      @default(false)
  completedAt    DateTime?    @map("completed_at")
  createdById    String       @map("created_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("ActivityAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("ActivityCreator", fields: [createdById], references: [id])

  @@map("activities")
}
