{
    "name": "crm-backend",
    "version": "1.0.0",
    "description": "Production-grade backend for CRM Manager",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "nodemon src/server.ts",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "ts-node prisma/seed.ts",
        "verify": "ts-node src/scripts/verify-api.ts",
        "backfill:perms": "ts-node src/scripts/backfill-permissions.ts",
        "test": "jest --runInBand",
        "test:run": "jest --runInBand --forceExit"
    },
    "dependencies": {
        "@getbrevo/brevo": "^6.0.2",
        "@prisma/client": "^5.10.2",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/multer": "^2.2.0",
        "@types/node": "^20.11.24",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.2.0",
        "prisma": "^5.10.2",
        "typescript": "^5.3.3",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/supertest": "^7.2.0",
        "fast-check": "^3.19.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.1.4",
        "ts-node": "^10.9.2"
    }
}
